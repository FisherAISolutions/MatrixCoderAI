# Matrix Coder AI environment example
# Never commit real secrets. Copy this file to .env.local for local development.

# Supabase browser client (optional; app falls back to local/session storage if missing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI provider keys (server-only)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# Vercel deployment integration (server-only token plus browser-safe configured flag)
VERCEL_TOKEN=
NEXT_PUBLIC_VERCEL_TOKEN_CONFIGURED=false
